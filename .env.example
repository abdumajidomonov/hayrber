# Odoo VPS — Environment Variables
# Bu faylni .env ga nusxa qiling va qiymatlarni o'zgartiring:
#   cp .env.example .env

# === DB ===
DB_USER=odoo
DB_PASSWORD=changeme_strong_password

# === Odoo portlari ===
ODOO_PORT=8069
ODOO_LONGPOLL_PORT=8072

# === Webhook (GitHub auto-deploy) ===
# GitHub webhook settings sahifasida shu sirni qo'ying.
# Tasodifiy ipni yarating: openssl rand -hex 32
WEBHOOK_SECRET=replace_with_random_hex_string
WEBHOOK_PORT=9000

# === Deploy ===
DEPLOY_BRANCH=main
REPO_DIR=/opt/odoo-vps
