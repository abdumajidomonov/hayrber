<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_picking_type_kanban_hide_deliveries" model="ir.ui.view">
        <field name="name">stock.picking.type.kanban.hide.deliveries</field>
        <field name="model">stock.picking.type</field>
        <field name="inherit_id" ref="stock.stock_picking_type_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//t[@t-name='card']" position="attributes">
                <attribute name="t-if">record.code.raw_value != 'outgoing'</attribute>
            </xpath>
        </field>
    </record>
</odoo>
