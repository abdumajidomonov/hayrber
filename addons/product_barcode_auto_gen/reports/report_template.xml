<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_issue_barcode_template">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <div class="page" style="padding:0; margin:0;">
                    <table style="width:100%; border-collapse:collapse; table-layout:fixed;">
                        <t t-foreach="range(0, len(docs), 3)" t-as="r">
                            <tr>
                                <t t-foreach="docs[r:r+3]" t-as="doc">
                                    <td style="width:33.33%; vertical-align:top; padding:3mm; box-sizing:border-box;">
                                        <div style="text-align:center; border:1.5pt solid #333; border-radius:4px; padding:6px; page-break-inside:avoid;">
                                            <div style="font-weight:bold; font-size:10pt; margin:3px 0; overflow:hidden; white-space:nowrap; text-overflow:ellipsis;">
                                                <t t-esc="doc.product_id.display_name"/>
                                            </div>
                                            <div style="font-size:8pt; margin:3px 0; color:#444;">
                                                <b>Miqdor:</b>&#160;<t t-esc="'%.2f' % doc.product_qty"/>&#160;<t t-esc="doc.uom_id.name"/>&#160;&#160;
                                                <b>Transfer:</b>&#160;<t t-esc="doc.picking_id.name"/>
                                            </div>
                                            <div style="margin:4px auto;">
                                                <img t-att-src="'/report/barcode/Code128/' + doc.barcode"
                                                     style="width:100%; max-width:160px; height:40px; display:block; margin:0 auto;"/>
                                            </div>
                                            <div style="font-size:9pt; font-weight:bold; letter-spacing:2px; margin:3px 0;">
                                                <t t-esc="doc.barcode"/>
                                            </div>
                                        </div>
                                    </td>
                                </t>
                                <t t-foreach="range(3 - len(docs[r:r+3]))" t-as="pad">
                                    <td style="width:33.33%;"></td>
                                </t>
                            </tr>
                        </t>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
