<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_issue_barcode_list" model="ir.ui.view">
        <field name="name">stock.issue.barcode.list</field>
        <field name="model">stock.issue.barcode</field>
        <field name="arch" type="xml">
            <list>
                <field name="barcode"/>
                <field name="product_id"/>
                <field name="product_qty"/>
                <field name="uom_id"/>
                <field name="picking_id"/>
                <field name="issue_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_stock_issue_barcode_form" model="ir.ui.view">
        <field name="name">stock.issue.barcode.form</field>
        <field name="model">stock.issue.barcode</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="barcode"/>
                        <field name="product_id"/>
                        <field name="product_qty"/>
                        <field name="uom_id"/>
                        <field name="picking_id"/>
                        <field name="issue_date"/>
                        <field name="state"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
