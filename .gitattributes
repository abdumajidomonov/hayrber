# Default behaviour: auto-detect text files, normalize to LF
* text=auto eol=lf

# Shell scripts MUST use LF (will fail on Linux otherwise)
*.sh text eol=lf
*.service text eol=lf
*.conf text eol=lf

# Python — LF
*.py text eol=lf

# YAML — LF
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
